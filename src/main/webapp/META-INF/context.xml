<?xml version="1.0" encoding="UTF-8"?>
<Context>
    <!-- 
      Tomcat JNDI JDBC DataSource Resource.
      This defines connection pooling parameters and holds database credentials.
    -->
    <Resource name="jdbc/SMSDB"
              auth="Container"
              type="javax.sql.DataSource"
              driverClassName="com.mysql.cj.jdbc.Driver"
              url="jdbc:mysql://localhost:3306/sms_db?useSSL=false&amp;allowPublicKeyRetrieval=true&amp;serverTimezone=UTC"
              username="root"
              password="Root1234"
              maxTotal="20"
              maxIdle="10"
              maxWaitMillis="10000"/>
</Context>
